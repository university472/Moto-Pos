# ============================================
# MOTO-POS BACKEND — Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Server
NODE_ENV=development
PORT=5000

# MongoDB — Local with Replica Set (required for transactions)
MONGODB_URI=mongodb://127.0.0.1:27017/moto-pos?replicaSet=rs0

# JWT Secrets (use strong random strings — min 32 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_min_32_characters_here
JWT_REFRESH_SECRET=your_super_secret_refresh_key_different_from_above

# JWT Expiry
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Cookie Settings
COOKIE_SECURE=false
# Set to true in production (requires HTTPS)